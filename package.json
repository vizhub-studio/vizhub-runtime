{
  "name": "@vizhub/runtime",
  "version": "4.6.0",
  "description": "Flexible runtime environment for data visualization sandboxes",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./worker": {
      "types": "./dist/worker.d.ts",
      "import": "./dist/worker.js",
      "require": "./dist/worker.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "demo": "cd demo-app; npm run dev",
    "typecheck": "tsc --noEmit",
    "prettier": "prettier {*.*,**/*.*} --write",
    "upgrade": "ncu -u",
    "preflight": "npm run build && npm run prettier && npm test && npm run typecheck"
  },
  "keywords": [],
  "author": "Curran Kelleher",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vizhub-core/vizhub-runtime.git"
  },
  "bugs": {
    "url": "https://github.com/vizhub-core/vizhub-runtime/issues"
  },
  "homepage": "https://github.com/vizhub-core/vizhub-runtime#readme",
  "devDependencies": {
    "@types/jsdom": "^28.0.3",
    "@types/node": "^26.0.1",
    "@types/uuid": "^11.0.0",
    "jsdom": "^29.1.1",
    "npm-check-updates": "^22.2.8",
    "prettier": "^3.9.0",
    "puppeteer": "^25.2.1",
    "rollup": "^4.62.2",
    "svelte": "^5.56.4",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@rollup/browser": "^4.62.2",
    "@vizhub/viz-types": "^0.5.0",
    "@vizhub/viz-utils": "^1.6.0",
    "magic-sandbox": "^2.5.0",
    "sucrase": "^3.35.1",
    "vizhub-libraries": "^1.8.0"
  }
}
